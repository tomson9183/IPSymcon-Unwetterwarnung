{
    "elements": [
        {
            "type": "Label",
            "caption": "🌧️ REGENRADAR – Karte (OpenStreetMap, mit Orten) zentriert auf deine Gemeinde mit animiertem Regenradar (Verlauf der letzten ~2 h). (Diese Instanz erzeugt KEINE Warnungen – dafür ist die „Warnzentrale“ zuständig.)"
        },
        {
            "type": "ValidationTextBox",
            "name": "Suche",
            "caption": "Gemeinde suchen (tippen, dann unten auswählen)",
            "onChange": "UWR_Search($id, $Suche);"
        },
        {
            "type": "Select",
            "name": "Bundesland",
            "caption": "… oder nach Bundesland filtern",
            "options": [],
            "onChange": "UWR_SetLand($id, $Bundesland);"
        },
        {
            "type": "Select",
            "name": "GemeindeARS",
            "caption": "Gemeinde (Kartenmitte)",
            "options": []
        },
        {
            "type": "Select",
            "name": "Zoom",
            "caption": "Kartenausschnitt",
            "options": [
                { "caption": "Ortsteil / Stadt (nah)", "value": 13 },
                { "caption": "Gemeinde + Nachbarorte", "value": 11 },
                { "caption": "Region (weit)", "value": 9 }
            ]
        },
        {
            "type": "Label",
            "caption": "Karte: © OpenStreetMap-Mitwirkende. Radar: RainViewer (u. a. auf Basis von DWD-Radardaten). Karte und Radar werden direkt im Browser geladen – kein Login nötig."
        }
    ],
    "actions": [
        {
            "type": "Button",
            "caption": "🔄 Vorschau aktualisieren",
            "onClick": "UWR_Reload($id);"
        }
    ],
    "status": [
        {
            "code": 102,
            "icon": "active",
            "caption": "Aktiv"
        },
        {
            "code": 104,
            "icon": "inactive",
            "caption": "Nicht konfiguriert – bitte eine Gemeinde wählen"
        }
    ]
}
