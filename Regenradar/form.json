{
    "elements": [
        {
            "type": "Label",
            "caption": "🌧️ REGENRADAR – Karte mit Ortsnamen (OpenStreetMap) + DWD-Niederschlagsradar als Animation. Der Symcon-Server baut die Bilder zusammen und bettet sie ein – das Anzeigegerät braucht KEINEN externen Internetzugriff. (Diese Instanz erzeugt KEINE Warnungen.)"
        },
        {
            "type": "ValidationTextBox",
            "name": "Suche",
            "caption": "Gemeinde suchen (tippen, dann unten auswählen)",
            "onChange": "UWR_Search($id, $Suche);"
        },
        {
            "type": "Select",
            "name": "Bundesland",
            "caption": "… oder nach Bundesland filtern",
            "options": [],
            "onChange": "UWR_SetLand($id, $Bundesland);"
        },
        {
            "type": "Select",
            "name": "GemeindeARS",
            "caption": "Gemeinde",
            "options": []
        },
        {
            "type": "ValidationTextBox",
            "name": "Ortsteil",
            "caption": "Ortsteil im Fokus (optional, z. B. Stadtteil/Dorf in der Gemeinde)"
        },
        {
            "type": "Select",
            "name": "Zoom",
            "caption": "Kartenausschnitt",
            "options": [
                { "caption": "Ortsteil / Stadt (nah)", "value": 1 },
                { "caption": "Gemeinde + Nachbarorte", "value": 2 },
                { "caption": "Region (weit)", "value": 3 }
            ]
        },
        {
            "type": "NumberSpinner",
            "name": "Frames",
            "caption": "Animation: Anzahl Zeitschritte (à 5 min)",
            "minimum": 1,
            "maximum": 16
        },
        {
            "type": "NumberSpinner",
            "name": "PlayDuration",
            "caption": "Abspieldauer je Klick (Sekunden)",
            "minimum": 5,
            "maximum": 600,
            "suffix": "s"
        },
        {
            "type": "NumberSpinner",
            "name": "RefreshInterval",
            "caption": "Bilder neu laden alle (Sekunden)",
            "minimum": 120,
            "maximum": 3600,
            "suffix": "s"
        },
        {
            "type": "Label",
            "caption": "Die Animation läuft nur auf ▶-Knopfdruck (für die eingestellte Dauer). Karte: © OpenStreetMap-Mitwirkende. Radar: DWD (maps.dwd.de). Ortsteil-Suche: Nominatim/OpenStreetMap."
        }
    ],
    "actions": [
        {
            "type": "Button",
            "caption": "🔄 Karte jetzt bauen / testen",
            "onClick": "UWR_RefreshTest($id);"
        }
    ],
    "status": [
        {
            "code": 102,
            "icon": "active",
            "caption": "Aktiv"
        },
        {
            "code": 104,
            "icon": "inactive",
            "caption": "Nicht konfiguriert – bitte eine Gemeinde wählen"
        }
    ]
}
