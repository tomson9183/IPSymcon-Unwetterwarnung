{
    "elements": [
        {
            "type": "Label",
            "caption": "🌧️ REGENRADAR – DWD-Niederschlagsradar als Kachel, zentriert auf deine Gemeinde (roter Punkt). Die Bilder werden vom Symcon-Server geladen und eingebettet – das Anzeigegerät braucht KEINEN externen Internetzugriff. (Diese Instanz erzeugt KEINE Warnungen – dafür ist die „Warnzentrale“ zuständig.)"
        },
        {
            "type": "ValidationTextBox",
            "name": "Suche",
            "caption": "Gemeinde suchen (tippen, dann unten auswählen)",
            "onChange": "UWR_Search($id, $Suche);"
        },
        {
            "type": "Select",
            "name": "Bundesland",
            "caption": "… oder nach Bundesland filtern",
            "options": [],
            "onChange": "UWR_SetLand($id, $Bundesland);"
        },
        {
            "type": "Select",
            "name": "GemeindeARS",
            "caption": "Gemeinde (Kartenmitte)",
            "options": []
        },
        {
            "type": "Select",
            "name": "Zoom",
            "caption": "Kartenausschnitt",
            "options": [
                { "caption": "Stadt (nah)", "value": 1 },
                { "caption": "Region", "value": 2 },
                { "caption": "Bundesland (weit)", "value": 3 }
            ]
        },
        {
            "type": "NumberSpinner",
            "name": "Frames",
            "caption": "Animation: Anzahl Zeitschritte (à 5 min)",
            "minimum": 1,
            "maximum": 16
        },
        {
            "type": "NumberSpinner",
            "name": "PlayDuration",
            "caption": "Abspieldauer je Klick (Sekunden)",
            "minimum": 5,
            "maximum": 600,
            "suffix": "s"
        },
        {
            "type": "NumberSpinner",
            "name": "RefreshInterval",
            "caption": "Bilder neu laden alle (Sekunden)",
            "minimum": 120,
            "maximum": 3600,
            "suffix": "s"
        },
        {
            "type": "Label",
            "caption": "Die Animation läuft nur, wenn der ▶-Knopf in der Kachel gedrückt wird (für die eingestellte Dauer), und stoppt dann wieder. Quelle: offener DWD-GeoServer (maps.dwd.de) – kein Login nötig."
        }
    ],
    "actions": [
        {
            "type": "Button",
            "caption": "🔄 Radar jetzt laden / testen",
            "onClick": "UWR_RefreshTest($id);"
        }
    ],
    "status": [
        {
            "code": 102,
            "icon": "active",
            "caption": "Aktiv"
        },
        {
            "code": 104,
            "icon": "inactive",
            "caption": "Nicht konfiguriert – bitte eine Gemeinde wählen"
        }
    ]
}
